import pytest
from {{ module_name }} import {{ class_name }}


@pytest.fixture
def plugin() -> {{ class_name }}:
    p = {{ class_name }}()
    p.init({})
    return p


class TestInit:
    def test_init_succeeds_with_empty_config(self):
        p = {{ class_name }}()
        p.init({})
        assert p._ready is True

    def test_init_merges_config(self):
        p = {{ class_name }}()
        p.init({"custom_key": "custom_value"})
        assert p.config.get("custom_key") == "custom_value"


class TestRun:
    def test_run_returns_dict(self, plugin):
        result = plugin.run({"input": "hello"})
        assert isinstance(result, dict)

    def test_run_without_init_raises(self):
        p = {{ class_name }}()
        with pytest.raises(RuntimeError, match="not initialized"):
            p.run({"input": "test"})

    def test_run_echo_payload(self, plugin):
        payload = {"input": "world"}
        result = plugin.run(payload)
        # Default implementation echoes back the payload
        assert result.get("status") == "ok"


class TestShutdown:
    def test_shutdown_marks_not_ready(self, plugin):
        plugin.shutdown()
        assert plugin._ready is False
