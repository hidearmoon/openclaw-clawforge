class {{ class_name }}(IPlugin):
    """
    {{ description }}

    Plugin type : provider
    Entry point : {{ module_name }}:{{ class_name }}

    A Provider plugin adapts an external LLM API to OpenClaw's unified
    provider interface, enabling chat completion (and optionally streaming,
    embeddings, and model listing).

    `run` payload actions:
      - chat_completion  : standard request/response
      - stream_completion: streaming via generator
      - list_models      : available model IDs
      - embeddings       : vector embeddings (optional)
    """

    DEFAULT_CONFIG: dict[str, Any] = {
        # "api_key": "",
        # "base_url": "https://api.example.com/v1",
        # "default_model": "gpt-4o",
        # "timeout": 30,
    }

    def __init__(self) -> None:
        self.config: dict[str, Any] = {}
        self._ready: bool = False
        self._client: Any = None  # replace with actual HTTP client

    # ──────────────────────────────────────────────────────────────────────────
    # Lifecycle
    # ──────────────────────────────────────────────────────────────────────────

    def init(self, config: dict[str, Any]) -> None:
        """Called once by OpenClaw after the plugin is loaded.

        Args:
            config: Merged config from openclaw.plugin.json and user settings.
        """
        self.config = {**self.DEFAULT_CONFIG, **config}
        # TODO: initialize HTTP client, validate API key, etc.
        # Example: self._client = httpx.Client(base_url=self.config["base_url"])
        self._ready = True
        logger.info("[{{ plugin_name }}] initialized with model=%s", self.config.get("default_model"))

    def run(self, payload: dict[str, Any]) -> Any:
        """Dispatch a provider operation.

        Args:
            payload: {
                "action": "chat_completion" | "stream_completion" | "list_models" | "embeddings",
                "model": str,      # optional override
                "messages": list,  # for chat actions
                "inputs": list,    # for embeddings
                ...
            }

        Returns:
            OpenClaw-compatible response dict, or a generator for streaming.
        """
        if not self._ready:
            raise RuntimeError("Plugin not initialized. Call init() first.")

        action = payload.get("action", "chat_completion")
        dispatch = {
            "chat_completion": self._chat_completion,
            "stream_completion": self._stream_completion,
            "list_models": self._list_models,
            "embeddings": self._embeddings,
        }
        handler = dispatch.get(action)
        if handler is None:
            raise ValueError(f"Unknown provider action: {action!r}")
        return handler(payload)

    def shutdown(self) -> None:
        """Called by OpenClaw before the plugin is unloaded."""
        self._ready = False
        if self._client is not None:
            # TODO: self._client.close()
            pass
        logger.info("[{{ plugin_name }}] shut down.")

