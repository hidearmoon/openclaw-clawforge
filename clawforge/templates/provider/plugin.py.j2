    def _chat_completion(self, payload: dict[str, Any]) -> dict[str, Any]:
        """Non-streaming chat completion."""
        model = payload.get("model", self.config.get("default_model", ""))
        messages = payload.get("messages", [])
        logger.debug("[{{ plugin_name }}] chat_completion model=%s msgs=%d", model, len(messages))

        # TODO: call self._client and parse response
