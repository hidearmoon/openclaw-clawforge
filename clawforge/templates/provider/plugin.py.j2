            ]
        }

    def _embeddings(self, payload: dict[str, Any]) -> dict[str, Any]:
        """Generate vector embeddings for input texts."""
        inputs = payload.get("inputs", [])
        model = payload.get("model", self.config.get("default_model", ""))
        # TODO: call embeddings API
        return {
